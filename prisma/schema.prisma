generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id                   String            @id @default(uuid())
  name                 String
  description          String?
  icon                 String?           // Lucide icon name
  color                String?           // Hex color for project
  customFieldTemplates String            @default("[]") @db.Text // JSON array of field definitions
  citationStyle        String            @default("bibtex") // bibtex | ieee | chicago
  sortOrder            Int               @default(0)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  resources            ProjectResource[]
  conversations        AiConversation[]
}

model Resource {
  id           String            @id @default(uuid())
  resourceType String            @default("paper") // paper | article | web_link | image | dataset | book
  title        String
  url          String?
  notes        String?           @db.Text // Markdown content
  customFields String            @default("{}") @db.Text // JSON key-value pairs
  typeFields   String            @default("{}") @db.Text // JSON — type-specific structured fields
  thumbnailUrl String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  projects     ProjectResource[]
  tags         ResourceTag[]
  conversations AiConversation[]
}

model Tag {
  id        String        @id @default(uuid())
  name      String        @unique
  color     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  resources ResourceTag[]
}

model ProjectResource {
  projectId  String
  resourceId String
  status     String   @default("backlog") // backlog | reading | core | archived
  starred    Boolean  @default(false)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([projectId, resourceId])
}

model ResourceTag {
  resourceId String
  tagId      String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([resourceId, tagId])
}

model AiConversation {
  id         String   @id @default(uuid())
  scope      String   // "resource" | "project"
  resourceId String?
  projectId  String?
  messages   String   @default("[]") @db.Text // JSON array of { role, content, timestamp }
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  project    Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
